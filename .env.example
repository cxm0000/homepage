# Optional — overrides default B2B sign-in URL (https://optionwise.se) for header “Log in”
# VITE_B2B_APP_URL=

# Optional — overrides default mailto for “Book a demo”
# VITE_BOOK_DEMO_URL=

# Optional — public site origin (no trailing slash); enables canonical + social image URLs in built HTML
# VITE_SITE_URL=https://your-org.github.io/your-repo

# Optional — override default store URLs (same defaults as OptionWiseB2BPlatform email templates /
# MobileDeepLinkLandingPage: App Store id6747363629, package com.optionwise.app).
# VITE_APP_STORE_URL=https://apps.apple.com/se/app/optionwise/id6747363629?l=en-GB
# VITE_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.optionwise.app

# Optional — company LinkedIn profile (footer); omit to hide the LinkedIn link
# VITE_LINKEDIN_URL=https://www.linkedin.com/company/your-company
